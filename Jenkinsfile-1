pipeline {
    agent any

    environment {
        HTTP_PROXY  = 'http://restrictedproxy.connect.te.com:80'
        HTTPS_PROXY = 'http://restrictedproxy.connect.te.com:80'
        http_proxy  = 'http://restrictedproxy.connect.te.com:80'
        https_proxy = 'http://restrictedproxy.connect.te.com:80'
        OUTPUT_DIR = "C:\\data"
    }

    stages {

        
stage('Python Check') {
    steps {
        bat '''
        echo HTTP_PROXY=%HTTP_PROXY%
        python -m pip install requests pandas openpyxl --proxy http://restrictedproxy.connect.te.com:80
        where python
        python -m pip list
        whoami
        python --version
        '''
    }
}

        stage('Run Script') {
            steps {
                bat '''
                    python redirect-check-2.py

                    if exist redirect_results*.xlsx (
                        move redirect_results*.xlsx %OUTPUT_DIR%
                    ) else (
                        echo No XLSX file found
                    )
                '''
            }
        }
    }

    post {
        success {
            echo "✅ Job completed"
        }
        failure {
            echo "❌ Job failed"
        }
    }
}
